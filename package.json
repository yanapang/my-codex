{
  "name": "oh-my-codex",
  "version": "0.8.12",
  "description": "Multi-agent orchestration layer for OpenAI Codex CLI",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "omx": "bin/omx.js"
  },
  "scripts": {
    "build": "tsc",
    "build:explore": "cargo build -p omx-explore-harness",
    "build:explore:release": "node scripts/build-explore-harness.js",
    "check:no-unused": "tsc -p tsconfig.no-unused.json",
    "dev": "tsc --watch",
    "lint": "biome lint .",
    "prepack": "npm run build && npm run build:explore:release",
    "setup": "node bin/omx.js setup",
    "doctor": "node bin/omx.js doctor",
    "ask:claude": "./scripts/ask-claude.sh",
    "ask:gemini": "./scripts/ask-gemini.sh",
    "test:explore": "cargo test -p omx-explore-harness && node --test dist/cli/__tests__/explore.test.js dist/hooks/__tests__/explore-routing.test.js",
    "test:node": "node --test $(find dist -name '*.test.js')",
    "test": "npm run build && npm run test:node && node scripts/generate-catalog-docs.js --check",
    "coverage:team-critical": "npm run build && c8 --all --src dist/team --src dist/state --include 'dist/team/**/*.js' --include 'dist/state/**/*.js' --exclude '**/__tests__/**' --reporter=text-summary --reporter=lcov --reporter=json-summary --report-dir coverage/team --check-coverage --lines=78 --functions=90 --branches=70 --statements=78 node --test $(find dist/team/__tests__ dist/state/__tests__ -name '*.test.js')",
    "test:compat:node": "npm run build && node --test dist/compat/__tests__/*.test.js",
    "test:compat:rust": "cargo build && OMX_COMPAT_TARGET=./target/debug/omx npm run test:compat:node",
    "build:sparkshell": "node scripts/build-sparkshell.mjs",
    "test:sparkshell": "node scripts/test-sparkshell.mjs",
    "postpack": "node scripts/cleanup-explore-harness.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "Cargo.toml",
    "Cargo.lock",
    "bin/",
    "dist/",
    "crates/",
    "agents/",
    "skills/",
    "prompts/",
    "templates/",
    "scripts/",
    "bin/native/",
    "scripts/build-sparkshell.mjs",
    "scripts/test-sparkshell.mjs"
  ],
  "keywords": [
    "codex",
    "openai",
    "cli",
    "agents",
    "orchestration",
    "multi-agent"
  ],
  "author": "Yeachan Heo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Yeachan-Heo/oh-my-codex.git"
  },
  "homepage": "https://yeachan-heo.github.io/oh-my-codex",
  "bugs": {
    "url": "https://github.com/Yeachan-Heo/oh-my-codex/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/node": "^22.19.11",
    "c8": "^10.1.3",
    "typescript": "^5.7.0"
  },
  "overrides": {
    "ajv": ">=8.18.0",
    "hono": ">=4.11.10"
  }
}
