{
  "id": "setup-dry-run-project",
  "command": ["setup", "--dry-run", "--scope", "project"],
  "env": {
    "HOME": "<fixture-home>",
    "CODEX_HOME": "<fixture-home>/.codex"
  },
  "expect": {
    "exit_code": 0,
    "stdout_contains": [
      "Using setup scope: project",
      "Generated AGENTS.md in project root.",
      "Setup complete! Run \"omx doctor\" to verify installation."
    ],
    "artifact_assertions": [
      ".omx/setup-scope.json is absent after dry-run",
      ".codex/ and .agents/ trees are absent after dry-run"
    ]
  },
  "normalizers": ["normalize-temp-paths", "normalize-path-separators"],
  "source_contracts": [
    "src/cli/__tests__/setup-scope.test.ts"
  ]
}
