{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": 1,
  "transition": {
    "baseline": "node-package-contract-must-remain-green",
    "transition": "npm-may-only-download-or-launch-native-binary",
    "cutover": "native-binaries-only",
    "cleanup": "remove-node-release-path-after-verifier-signoff"
  },
  "bundles": [
    {
      "platform": "linux-x64",
      "target": "x86_64-unknown-linux-gnu",
      "archive": "omx-x86_64-unknown-linux-gnu.tar.gz",
      "binary_path": "omx-x86_64-unknown-linux-gnu/omx",
      "smoke": ["--help", "version", "doctor", "team --help"]
    },
    {
      "platform": "macos-arm64",
      "target": "aarch64-apple-darwin",
      "archive": "omx-aarch64-apple-darwin.tar.gz",
      "binary_path": "omx-aarch64-apple-darwin/omx",
      "smoke": ["--help", "version", "doctor", "ask --help"]
    },
    {
      "platform": "macos-x64",
      "target": "x86_64-apple-darwin",
      "archive": "omx-x86_64-apple-darwin.tar.gz",
      "binary_path": "omx-x86_64-apple-darwin/omx",
      "smoke": ["--help", "version", "doctor"]
    },
    {
      "platform": "windows-x64",
      "target": "x86_64-pc-windows-msvc",
      "archive": "omx-x86_64-pc-windows-msvc.zip",
      "binary_path": "omx-x86_64-pc-windows-msvc/omx.exe",
      "smoke": ["--help", "version", "doctor", "team --help"]
    }
  ],
  "npm_transition_policy": {
    "allowed": true,
    "launcher_only": true,
    "forbidden": [
      "execute-cli-logic-through-node",
      "ship-dist-as-primary-runtime",
      "publish-bin-omx-js-as-supported-cutover-artifact"
    ]
  }
}
